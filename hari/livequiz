import java.util.*;

class Participant {
    String name;
    int score;

    Participant(String name, int score) {
        this.name = name;
        this.score = score;
    }
}

public class LiveQuizSystem {

    static Map<String, Participant> map = new HashMap<>();

    public static void addParticipant(String name, int score) {
        Participant p = new Participant(name, score);
        map.put(name, p);
    }

    public static void updateScore(String name, int newScore) {
        if (map.containsKey(name)) {
            map.get(name).score = newScore;
        } else {
            System.out.println("Participant not found!");
        }
    }

    public static void displayRankings() {
        List<Participant> list = new ArrayList<>(map.values());

        list.sort((a, b) -> b.score - a.score);

        System.out.println("\n--- Leaderboard ---");
        int rank = 1;
        for (Participant p : list) {
            System.out.println(rank + ". " + p.name + " - " + p.score);
            rank++;
        }
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        while (true) {
            System.out.println("\n1. Add Participant");
            System.out.println("2. Update Score");
            System.out.println("3. Show Rankings");
            System.out.println("4. Exit");

            int choice = sc.nextInt();
            sc.nextLine();

            switch (choice) {
                case 1:
                    System.out.print("Enter name: ");
                    String name = sc.nextLine();
                    System.out.print("Enter score: ");
                    int score = sc.nextInt();
                    addParticipant(name, score);
                    break;

                case 2:
                    System.out.print("Enter name: ");
                    name = sc.nextLine();
                    System.out.print("Enter new score: ");
                    int newScore = sc.nextInt();
                    updateScore(name, newScore);
                    break;

                case 3:
                    displayRankings();
                    break;

                case 4:
                    System.exit(0);

                default:
                    System.out.println("Invalid choice!");
            }
        }
    }
}